function getClosestPlayerToCursor()
	local Target = nil
	local Distance = 9e9
	local Camera = game:GetService("Workspace").CurrentCamera
	for _, v in pairs(game.Players:GetPlayers()) do 
		if v ~= game.Players.LocalPlayer and v.Character and v.Character:FindFirstChild("Head") and v.Character:FindFirstChildOfClass("Humanoid") and v.Character:FindFirstChildOfClass("Humanoid").Health > 0 then
			local Enemy = v.Character
			local CastingFrom = CFrame.new(Camera.CFrame.Position, Enemy:FindFirstChild("Head").CFrame.Position) * CFrame.new(0, 0, -4)
			local RayCast = Ray.new(CastingFrom.Position, CastingFrom.LookVector * 500)
			local World, ToSpace = game:GetService("Workspace"):FindPartOnRayWithIgnoreList(RayCast, {game.Players.LocalPlayer.Character:FindFirstChild("Head")});
			local RootWorld = (Enemy:FindFirstChild("Head").CFrame.Position - ToSpace).magnitude
			if RootWorld < 4 then		
				local RootPartPosition, Visible = Camera:WorldToViewportPoint(Enemy:FindFirstChild("Head").Position)
				if Visible then
					local Real_Magnitude = (Vector2.new(game.Players.LocalPlayer:GetMouse().X, game.Players.LocalPlayer:GetMouse().Y) - Vector2.new(RootPartPosition.X, RootPartPosition.Y)).Magnitude
					if Real_Magnitude < Distance and Real_Magnitude < 9e9 then
						Distance = Real_Magnitude
						Target = Enemy
					end
				end
			end
		end
	end
	return Target
end
local highlight = Instance.new("Highlight")
highlight.Parent = game.CoreGui
game.Players.LocalPlayer:GetMouse().KeyDown:Connect(function(k)
	if k ~= "q" then return end
	if enabled then
		enabled = false
	else
		enabled = true 
		monpenis = getClosestPlayerToCursor()
	end    
end)
game:GetService("RunService").Heartbeat:Connect(function()
    if enabled and monpenis ~= nil then
        highlight.Parent = monpenis
    else
        highlight.Parent = nil

    end
end)
local __index
__index = hookmetamethod(game, "__index", function(t, k)
    if t:IsA("Mouse") and (k == "Hit" or k == "Target") and monpenis ~= nil and enabled then
        return (k == "Hit" and monpenis.Head.CFrame+monpenis.HumanoidRootPart.Velocity*.1 or monpenis.Head)
    end
    return __index(t, k)
end)
